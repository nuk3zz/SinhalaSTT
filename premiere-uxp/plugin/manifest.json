{
  "manifestVersion": 5,
  "id": "com.sinhalastt.premiere",
  "name": "SinhalaSTT",
  "version": "0.1.0",
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "sinhalastt.panel",
      "label": { "default": "SinhalaSTT" },
      "minimumSize": { "width": 320, "height": 360 },
      "preferredDockedSize": { "width": 380, "height": 620 },
      "preferredFloatingSize": { "width": 420, "height": 660 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "http://localhost",
        "http://localhost:8765",
        "http://127.0.0.1",
        "http://127.0.0.1:8765"
      ]
    },
    "localFileSystem": "request",
    "clipboard": "readAndWrite"
  },
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/icon.png",
      "scale": [1, 2],
      "theme": ["darkest", "dark", "medium", "lightest", "light", "all"],
      "species": ["generic"]
    }
  ]
}
